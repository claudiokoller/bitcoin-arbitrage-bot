{
    "poll_interval": 30,
    "daily_volume_limit_usd": 2000.0,
    "auto_buy_and_fund": true,
    "auto_confirm_payment": false,
    "db_path": "trades.db",
    "exchanges": {
        "kraken_chf": {
            "enabled": true,
            "api_key": "YOUR_KRAKEN_API_KEY",
            "api_secret": "YOUR_KRAKEN_API_SECRET",
            "trading_pair": "XBTCHF",
            "max_buy_fiat": 2500.0,
            "withdrawal_key": "HotWallet"
        },
        "kraken_eur": {
            "enabled": false,
            "api_key": "YOUR_KRAKEN_API_KEY",
            "api_secret": "YOUR_KRAKEN_API_SECRET",
            "trading_pair": "XXBTZEUR",
            "max_buy_fiat": 2500.0,
            "withdrawal_key": "HotWallet"
        }
    },
    "auto_buy_escrow": {
        "enabled": true,
        "check_interval_sec": 600,
        "amounts": [500, 400, 300, 200],
        "premium": 5.5,
        "exclude_methods": ["revolut"],
        "min_wallet_fund_chf": 100
    },
    "platforms": {
        "peach": {
            "enabled": true,
            "api_base": "https://api.peachbitcoin.com/v1",
            "private_key_hex": "YOUR_PEACH_PRIVATE_KEY",
            "unique_id": "YOUR_PEACH_UNIQUE_ID",
            "refund_address": "YOUR_BTC_REFUND_ADDRESS",
            "pgp_public_key": "",
            "target_premium": 6.0,
            "min_amount_sats": 50000,
            "max_amount_sats": 500000,
            "payment_methods": {
                "CHF": ["twint", "revolut", "skrill"],
                "EUR": ["sepa", "instantSepa", "revolut", "wise", "skrill", "n26", "paysera"],
                "USD": ["revolut", "wise", "skrill"]
            },
            "payment_data_raw": {
                "twint": "+41XXXXXXXXX",
                "revolut": "@username",
                "wise": "@username",
                "skrill": "your@email.com",
                "n26": "+41XXXXXXXXX",
                "paysera": "+41XXXXXXXXX"
            },
            "payment_data_info": {
                "beneficiary": "Your Name",
                "twint": {"phone": "+41XXXXXXXXX"},
                "revolut": {"userName": "@username", "reference": ""},
                "wise": {"userName": "@username", "reference": ""},
                "skrill": {"email": "your@email.com"},
                "n26": {"phone": "+41XXXXXXXXX", "email": "your@email.com"},
                "paysera": {"phone": "+41XXXXXXXXX"}
            },
            "sepa_accounts": [
                {"iban": "DEXXXXXXXXXX", "bic": "NTSBDEB1XXX", "beneficiary": "Your Name", "name": "N26", "instant": true},
                {"iban": "BEXXXXXXXXXX", "bic": "TRWIBEB1XXX", "beneficiary": "Your Name", "name": "Wise", "instant": true},
                {"iban": "CHXXXXXXXXXX", "bic": "SWQBCHZZXXX", "beneficiary": "Your Name", "name": "Yuh", "instant": false, "instant_fallback": "Paysera"},
                {"iban": "LTXXXXXXXXXX", "bic": "EVIULT2VXXX", "beneficiary": "Your Name", "name": "Paysera", "instant": true}
            ]
        }
    }
}
